# Cloudflare API Configuration
# Preferred: a scoped API Token (Account:Cloudflare Tunnel:Edit, Zone:DNS:Edit,
# Zone:Read, Account Settings:Read). Create it at My Profile > API Tokens.
CF_API_TOKEN=your_cloudflare_scoped_api_token

# Legacy fallback, only used if CF_API_TOKEN is unset. Grants full account
# access -- see README.md "Security note".
# CF_API_KEY=your_cloudflare_global_api_key
# CF_API_EMAIL=your_cloudflare_email

CF_ACCOUNT_ID=your_cloudflare_account_id
CF_TUNNEL_ID=your_cloudflare_tunnel_id
CF_ZONE_ID=your_cloudflare_zone_id

# Application Configuration
# Fallback reconciliation interval, in ms -- not the primary detection path
# anymore (see README "Why events, not polling"), just a backstop in case
# the Docker event stream ever drops something. A long interval is fine.
TUNNELDOCK_WATCH_INTERVAL=60000

# How long a hostname must stay inactive (container stopped/removed) before
# its DNS record and ingress rule are actually deleted, in ms. Default 5min
# -- avoids churn from a container that's briefly down for a manual restart
# or a config change. Set to 0 to delete immediately (old behavior).
TUNNELDOCK_DELETE_GRACE_PERIOD_MS=300000

# Web dashboard port (managed routes, seen containers, recent logs).
WEB_UI_PORT=9091
